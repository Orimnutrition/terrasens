{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri/refs/heads/v2/crates/tauri-utils/schema.json",
  "productName": "AGRORIM",
  "version": "0.2.0",
  "identifier": "com.orim.agrorim",
  "build": {
    "frontendDist": "../src-frontend",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "AGRORIM™ — IA Agronomique Souveraine",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
